#! /usr/bin/env python3

import sys

IND="  "
indent = 0
while True:
    c = sys.stdin.read(1)
    if not c:
        break
    if c == '{':
        indent += 1
        print('{\n'+IND*indent, end="")
    elif c == '}':
        indent -= 1
        print('\n'+IND*indent+'}', end="")
    else:
        print(c, end="")

